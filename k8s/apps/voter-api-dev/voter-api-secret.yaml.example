# voter-api-secret — DO NOT commit actual secret values!
#
# Create the secret using an env file (keeps credentials out of shell history):
#
# 1. Create a local env file (never commit this):
#
#    cat > /tmp/voter-api.env <<'EOF'
#    DATABASE_URL=postgresql+asyncpg://voter_api:<password>@postgresql.civpulse-infra.svc.cluster.local:5432/voter_api
#    JWT_SECRET_KEY=<your-jwt-secret-key-min-32-chars>
#    TOTP_SECRET_ENCRYPTION_KEY=<fernet-key-from-cryptography>
#    EOF
#    chmod 600 /tmp/voter-api.env
#
# 2. Create the secret from the env file:
#
#    kubectl create secret generic voter-api-secret \
#      --namespace civpulse-dev \
#      --from-env-file=/tmp/voter-api.env
#
# 3. Remove the temp file:
#
#    shred -u /tmp/voter-api.env
#
# To generate a TOTP encryption key:
#   python -c 'from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())'
