# voter-api-secret — DO NOT commit actual secret values!
#
# Create the secret manually on the cluster:
#
#   kubectl create secret generic voter-api-secret \
#     --namespace civpulse-dev \
#     --from-literal=DATABASE_URL=postgresql+asyncpg://voter_api:<password>@postgresql.civpulse-infra.svc.cluster.local:5432/voter_api \
#     --from-literal=JWT_SECRET_KEY=<your-jwt-secret-key-min-32-chars> \
#     --from-literal=TOTP_SECRET_ENCRYPTION_KEY=<fernet-key-from-cryptography>
#
# To generate a TOTP encryption key:
#   python -c 'from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())'
