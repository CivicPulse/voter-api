# Grafana admin credentials — DO NOT commit actual values
#
# Create this secret manually on the cluster:
#
#   kubectl -n civpulse-infra create secret generic grafana-admin-credentials \
#     --from-literal=admin-user=admin \
#     --from-literal=admin-password="$(openssl rand -base64 24)"
#
# After Grafana is running, create a service account for MCP integration:
#
#   1. Log into Grafana at http://thor.tailb56d83.ts.net/grafana
#   2. Go to Administration > Service Accounts
#   3. Create a service account named "claude-code-mcp"
#   4. Assign Viewer role
#   5. Generate an API token
#   6. Add to .mcp.json (gitignored):
#
#      {
#        "mcpServers": {
#          "grafana": {
#            "command": "npx",
#            "args": ["-y", "@modelcontextprotocol/server-grafana"],
#            "env": {
#              "GRAFANA_URL": "http://thor.tailb56d83.ts.net/grafana",
#              "GRAFANA_API_KEY": "<service-account-token>"
#            }
#          }
#        }
#      }
