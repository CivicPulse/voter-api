# Zitadel Kubernetes Secrets — DO NOT commit actual values
#
# Create these secrets manually on the cluster:
#
# 1. Master key (32-char symmetric key, never changes after initial setup):
#
#    MASTERKEY=$(openssl rand -base64 24 | head -c 32)
#    kubectl -n civpulse-infra create secret generic zitadel-masterkey \
#      --from-literal=masterkey="$MASTERKEY"
#
# 2. Database credentials (YAML format required by the Helm chart):
#
#    kubectl -n civpulse-infra create secret generic zitadel-db-credentials \
#      --from-literal=config.yaml="
#    Database:
#      Postgres:
#        User:
#          Password: <zitadel-user-password>
#        Admin:
#          Password: <postgres-admin-password>
#    "
