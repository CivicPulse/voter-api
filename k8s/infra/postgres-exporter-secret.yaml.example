# postgres_exporter credentials — DO NOT commit actual values
#
# Prerequisites: create a read-only monitoring user in PostgreSQL:
#
#   CREATE USER exporter WITH PASSWORD '<secure-password>';
#   GRANT pg_monitor TO exporter;
#
# Create the secret using an env file (keeps credentials out of shell history):
#
# 1. Create a local env file (never commit this):
#
#    cat > /tmp/postgres-exporter.env <<'EOF'
#    DATA_SOURCE_NAME=postgresql://exporter:<password>@postgresql.civpulse-infra.svc.cluster.local:5432/postgres?sslmode=require
#    EOF
#    chmod 600 /tmp/postgres-exporter.env
#
# 2. Create the secret from the env file:
#
#    kubectl -n civpulse-infra create secret generic postgres-exporter-credentials \
#      --from-env-file=/tmp/postgres-exporter.env
#
# 3. Remove the temp file:
#
#    shred -u /tmp/postgres-exporter.env
